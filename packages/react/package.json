{
  "name": "@simple-presence/react",
  "version": "0.2.1",
  "description": "React hooks for real-time user presence tracking",
  "keywords": [
    "hooks",
    "online-users",
    "presence",
    "react",
    "real-time",
    "websocket"
  ],
  "homepage": "https://simple-presence.erickr.dev",
  "bugs": {
    "url": "https://github.com/ErickCReis/simple-presence/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ErickCReis/simple-presence.git",
    "directory": "packages/react"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown --platform browser src/index.tsx",
    "dev": "tsdown --watch --platform browser src/index.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@simple-presence/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
