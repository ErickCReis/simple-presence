{
  "name": "@simple-presence/core",
  "version": "0.3.2",
  "description": "Real-time user presence tracking for any JavaScript application",
  "keywords": [
    "live-count",
    "online-users",
    "presence",
    "real-time",
    "user-tracking",
    "websocket"
  ],
  "homepage": "https://simple-presence.erickr.dev",
  "bugs": {
    "url": "https://github.com/ErickCReis/simple-presence/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ErickCReis/simple-presence.git",
    "directory": "packages/core"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun pm pack --filename=packages/core/core.tgz"
  },
  "dependencies": {
    "@orpc/client": "^1.14.1",
    "partysocket": "^1.1.18"
  },
  "devDependencies": {
    "@simple-presence/contracts": "workspace:*",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3"
  }
}
