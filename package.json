{
  "name": "simple-presence",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "preinstall": "node -e \"if(!process.env.npm_execpath?.includes('bun')){console.error('Use bun as the package manager');process.exit(1)}\"",
    "check": "oxfmt --check && oxlint",
    "check:fix": "oxfmt && oxlint --fix",
    "typecheck": "bun run --filter '*' typecheck",
    "build": "bun run --filter '*' build",
    "dev": "bun run --parallel --filter '*' dev",
    "deploy": "bun run --filter '*' deploy"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0"
  },
  "packageManager": "bun@1.3.11"
}
